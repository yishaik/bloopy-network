NODE_ENV=development
PORT=3000
PUBLIC_BASE_URL=http://localhost:3000
DATABASE_URL=postgres://bloopy:bloopy@localhost:5432/bloopy
TELEGRAM_MANAGER_BOT_TOKEN=
TELEGRAM_MANAGER_BOT_USERNAME=
# generate with: openssl rand -base64 24 (min 16 chars; placeholders are rejected in production)
TELEGRAM_WEBHOOK_SECRET=replace-with-random-secret
# REQUIRED — generate with: openssl rand -base64 32 (the old all-zero key is rejected at boot)
APP_ENCRYPTION_KEY=GENERATE_ME
DEMO_MODE=true
ALLOW_LOCAL_AI=true
CHARACTER_GENESIS_ENABLED=true
IMPOSSIBLE_DOOR_ENABLED=true
DOOR_CLIFFHANGER_DELAY_SECONDS=3600
PLATFORM_AI_ENABLED=true
PLATFORM_AI_BASE_URL=
PLATFORM_AI_MODEL=
PLATFORM_AI_API_KEY=
PLATFORM_AI_ALLOWED_MODELS=
PLATFORM_AI_INPUT_USD_PER_MILLION=
PLATFORM_AI_OUTPUT_USD_PER_MILLION=
PLATFORM_AI_MONTHLY_BUDGET_USD=10
AI_PLATFORM_DAILY_REQUEST_LIMIT=20
AI_BYOK_DAILY_REQUEST_LIMIT=100
AI_PLATFORM_ENRICHMENT_PERCENT=30
AI_TIMEOUT_MS=4500
AI_MAX_OUTPUT_TOKENS=160
PROACTIVE_DELAY_SECONDS=120

# Telegram runtime. Keep the two managed-bot surfaces false in production until the human verification gates in docs/ALPHA_TESTING.md pass.
TELEGRAM_INGRESS_ENABLED=true
MANAGED_BOT_FLEET_ENABLED=false
BOT_TO_BOT_ENABLED=false
OUTBOX_ENABLED=true
DEGRADED_MODE=false
BOT_INTERACTION_TTL_SECONDS=600
BOT_INTERACTION_MAX_TURNS=4
BOT_INTERACTION_PAIR_HOURLY_LIMIT=5
BOT_INTERACTION_OWNER_DAILY_LIMIT=20
PROCESSED_UPDATE_RETENTION_DAYS=7
TELEGRAM_UPDATE_LEASE_SECONDS=60
OUTBOX_LEASE_SECONDS=45
TELEGRAM_UPDATE_BATCH_SIZE=20
OUTBOX_BATCH_SIZE=20
TELEGRAM_UPDATE_MAX_ATTEMPTS=5
OUTBOX_MAX_ATTEMPTS=7
READY_MAX_UPDATE_BACKLOG=500
READY_MAX_OUTBOX_BACKLOG=500

# optional; admin endpoints stay disabled unless set (min 32 chars): openssl rand -base64 32
ADMIN_API_KEY=
